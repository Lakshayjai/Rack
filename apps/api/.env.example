# PostgreSQL (matches docker-compose.yml; host port 5433 to avoid clashing with a native Postgres on 5432)
DATABASE_URL="postgresql://wardrobe:wardrobe@localhost:5433/wardrobe_db?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3005
# Origin allowed by CORS (the Next.js web app)
WEB_ORIGIN="http://localhost:3000"
# Public base URL of this API (used to build local image URLs when Cloudinary is off)
PUBLIC_API_URL="http://localhost:3005"

# Cloudinary — create a free account at https://cloudinary.com and paste your credentials
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Background removal
# Local rembg microservice (see services/rembg). Leave as-is for the default setup.
REMBG_URL="http://localhost:7000/remove"
# Optional fallback — used only if REMBG_URL is unreachable and this key is set.
REMOVE_BG_API_KEY=""
