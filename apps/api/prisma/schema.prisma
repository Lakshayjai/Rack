generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  username      String
  gender        String? // male | female — tailors category/type options in the UI
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clothingItems ClothingItem[]
  outfits       Outfit[]
}

model ClothingItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl  String
  thumbUrl  String?
  category  String // TOP | BOTTOM | DRESS | SHOE | ACCESSORY | OUTERWEAR
  subtype   String? // e.g. t-shirt | jeans | saree | kurta — gender-aware garment type (ethnic wear included)
  colors    String[]
  styles    String[] // casual | formal | streetwear | smart-casual | sport | ethnic
  occasions String[] // daily | work | party | gym | date | wedding | festival | puja
  brand     String?
  notes     String?
  // Items linked as a set (lehenga + choli + dupatta, kurta + pajama); read as symmetric.
  pairedItemIds String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Outfit {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  canvasState      Json
  exportedImageUrl String?
  itemIds          String[]
  tags             String[]   @default([]) // e.g. season / occasion labels
  wornDates        DateTime[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([userId])
}
